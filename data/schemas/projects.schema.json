{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trellis://schemas/projects.schema.json",
  "title": "Projects",
  "description": "七個並行專案定義(PRD §4.1)",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "name", "deadline", "note", "progress", "status"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^P[1-7]$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "deadline": {
        "type": "string",
        "minLength": 1,
        "description": "人類可讀期限描述,如「2026/7/31」或「2027/1 或 2027/7 口試」"
      },
      "deadlineDate": {
        "type": ["string", "null"],
        "format": "date",
        "description": "可排序的估計 ISO 日期;雙軌或無明確日期者為 null"
      },
      "note": {
        "type": "string"
      },
      "progress": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      },
      "status": {
        "type": "string",
        "enum": ["not_started", "in_progress", "behind", "done"]
      },
      "linkedMilestoneTrack": {
        "type": ["string", "null"],
        "enum": ["dual", null],
        "description": "P2 連結 milestones.json 雙軌看板"
      },
      "updatedAt": {
        "type": ["string", "null"],
        "format": "date-time",
        "description": "最近一次更新時間,供「今天」頁最近更新彙整使用"
      }
    }
  },
  "minItems": 1
}
